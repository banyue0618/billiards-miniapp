/* components/store-card/index.wxss */
@import "../../styles/iconfont.wxss";

.store-card-component {
  background-color: var(--card-background-color);
  border-radius: 20rpx; /* 更小的圆角 */
  padding: 24rpx; /* 减少内边距 */
  margin-bottom: 24rpx; /* 减少底部间距 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08); /* 更柔和的阴影 */
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.store-card-component:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.image-placeholder-wrapper {
  width: 100%;
  height: 260rpx; /* 减小高度 */
  background-color: #e9ecef;
  border-radius: 12rpx; /* 更小的圆角 */
  margin-bottom: 20rpx; /* 减少底部间距 */
  overflow: hidden;
  position: relative;
}

.store-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

.store-card-component:active .store-image {
  transform: scale(1.02);
}

.name-status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx; /* 减少底部间距 */
}

.store-name-text {
  font-size: 30rpx; /* 减小字号 */
  font-weight: 600; /* 减轻字重 */
  color: #1d1d1f; /* 使用HTML中的颜色 */
  letter-spacing: 0.2px; /* 减少字符间距 */
}

.status-badge {
  font-size: 26rpx; /* 增大字号 */
  padding: 6rpx 16rpx; /* 增加内边距 */
  border-radius: 10rpx; /* 适当圆角 */
  font-weight: 600; /* 增加字重 */
  color: white;
  margin-left: 10rpx; /* 增加左边距 */
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1); /* 添加微弱阴影 */
}

.status-badge.status-open {
  background-color: var(--green-color);
}

.status-badge.status-closed {
  background-color: var(--gray-color);
}

.status-badge.status-full {
  background-color: var(--orange-color);
}

.table-info-text {
  font-size: 24rpx; /* 减小字号 */
  color: #6e6e73; /* 使用HTML中的次要文本颜色 */
  margin-bottom: 14rpx; /* 减少底部间距 */
  font-weight: 400; /* 减轻字重 */
}

.available-tables {
  color: var(--green-color);
  font-weight: 500; /* 减轻字重 */
  letter-spacing: 0.2px;
}
.available-tables.tables-full {
  color: var(--orange-color);
}

.location-info-row,
.hours-info-row {
  font-size: 24rpx; /* 减小字号 */
  color: #6e6e73; /* 使用HTML中的次要文本颜色 */
  margin-bottom: 8rpx; /* 减少底部间距 */
  display: flex;
  align-items: center;
  font-weight: 400; /* 减轻字重 */
}

.menu-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6e6e73;
}

.info-icon {
  width: 24rpx; /* 减小图标大小 */
  height: 24rpx;
  margin-right: 10rpx; /* 减少右边距 */
  opacity: 0.7; /* 降低不透明度 */
}

.location-text,
.hours-text {
  flex: 1;
  line-height: 1.4; /* 减少行高 */
}

.price-info-text {
  font-size: 24rpx; /* 减小字号 */
  color: #6e6e73; /* 使用HTML中的次要文本颜色 */
  font-weight: 400; /* 减轻字重 */
  margin: 14rpx 0; /* 减少上下间距 */
}

.price-value {
  color: var(--interactive-color); /* 使用HTML中的交互色 */
  font-weight: 500; /* 减轻字重 */
  letter-spacing: 0.2px;
}

.announcement-section {
  font-size: 22rpx; /* 减小字号 */
  color: #86868b; /* 使用HTML中的第三级文本颜色 */
  background-color: #f0f0f5;
  padding: 12rpx 16rpx; /* 减少内边距 */
  border-radius: 8rpx; /* 减小圆角 */
  margin-top: 14rpx; /* 减少顶部间距 */
  line-height: 1.4; /* 减少行高 */
}

.announcement-text {
  display: block;
}

/* 添加卡片阴影和悬停效果 */
@keyframes cardHover {
  0% {
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  }
  100% {
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  }
}