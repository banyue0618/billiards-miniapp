<!-- 扫码结果弹窗 -->
<view class="modal-overlay {{showModal ? 'active' : ''}}" bindtap="closeModal">
  <view class="modal-container" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">确认开台</text>
      <view class="modal-close" bindtap="closeModal">×</view>
    </view>
    
    <view class="modal-body">
      <view class="info-row">
        <text class="info-label">桌台</text>
        <text class="info-value">{{scanResult.tableNumber}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">类型</text>
        <text class="info-value">{{scanResult.type === 'standard' ? '标准' : '中式'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">计费</text>
        <text class="info-value price">{{pricingText}}</text>
      </view>
      
      <view class="price-detail" wx:if="{{scanResult.pricerRule.ruleType === 2}}">
        <view class="price-title">阶梯计费详情：</view>
        <view 
          class="price-item" 
          wx:for="{{scanResult.pricerRule.ladderRules}}" 
          wx:key="start_minutes"
        >
          <text>{{item.start_minutes}}分钟 - </text>
          <text wx:if="{{item.end_minutes}}">{{item.end_minutes}}分钟</text>
          <text wx:else>之后</text>
          <text>{{formatter.formatTierPrice(item.price)}}元/分钟</text>
        </view>
      </view>
      
      <view class="price-notes" wx:if="{{scanResult.pricerRule.min_consumption || scanResult.pricerRule.max_price}}">
        <view wx:if="{{scanResult.pricerRule.min_consumption}}">
          <text class="info-label">最低消费：</text>
          <text class="info-value">{{scanResult.pricerRule.min_consumption}}分钟</text>
        </view>
        <view wx:if="{{scanResult.pricerRule.max_price}}">
          <text class="info-label">封顶价格：</text>
          <text class="info-value">{{formatter.formatPrice(scanResult.pricerRule.max_price)}}元</text>
        </view>
      </view>
      
      <view class="member-discount" wx:if="{{scanResult.pricerRule.memberDiscount && userInfo.is_member}}">
        <text class="info-label">会员折扣：</text>
        <text class="info-value discount">{{scanResult.pricerRule.memberDiscount * 10}}折</text>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeModal">取消</button>
      <button class="btn-confirm" bindtap="handleStartTable">立即开台</button>
    </view>
  </view>
</view>

<!-- 使用登录弹窗组件 -->
<login-modal show="{{showLoginModal}}" bind:close="closeLoginModal" bind:login-success="onLoginSuccess"></login-modal> 