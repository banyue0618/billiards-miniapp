<!-- 扫码开台页面 -->

<!-- 使用ongoing-order-card组件 - 统一与首页的卡片样式展示 -->
<view class="index-page-container">
  <ongoing-order-card></ongoing-order-card>
</view>

<view class="scan-container">
  <!-- 扫码说明卡片 -->
  <view class="scan-guide">
    <view class="guide-title">扫描桌台二维码开台</view>
    <view class="guide-tips">
      <view class="guide-tip">
        <view class="guide-tip-number">1</view>
        <view class="guide-tip-text">对准桌台二维码进行扫描</view>
      </view>
      <view class="guide-tip">
        <view class="guide-tip-number">2</view>
        <view class="guide-tip-text">确认桌台和价格信息</view>
      </view>
      <view class="guide-tip">
        <view class="guide-tip-number">3</view>
        <view class="guide-tip-text">点击开台即可使用</view>
      </view>
      <view class="guide-tip">
        <view class="guide-tip-number">4</view>
        <view class="guide-tip-text">以分钟计费，最低消费时长为1分钟</view>
      </view>
    </view>
  </view>
  
  <!-- 扫码按钮 -->
  <view class="scan-action">
    <button class="scan-button {{isOngoing ? 'btn-disabled' : ''}}" bindtap="startScan"  disabled="{{isOngoing}}">点击扫码</button>
  </view>
  
