/* pages/prepay/prepay.wxss */
page {
  background-color: #f0f0f5; /* 苹果风格的浅灰色背景 */
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
  color: #333;
}

.container.prepay-container {
  padding: 20rpx;
  box-sizing: border-box;
}

.page-header {
  text-align: center;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1c1c1e; /* 苹果风格的深色文字 */
}

/* 卡片通用样式 */
.info-card {
  background-color: #fff;
  border-radius: 20rpx; /* 苹果风格的圆角 */
  margin-bottom: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05); /* 轻微阴影效果 */
}

.section-title-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1c1c1e;
}

/* 金额选择 */
.amount-selection-card .amount-options {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.amount-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 45%;
  padding: 40rpx 0;
  border: 1px solid #e5e5ea; /* 苹果风格的分割线颜色 */
  border-radius: 16rpx;
  background-color: #f9f9f9;
  transition: all 0.2s ease-in-out;
  cursor: pointer; /* 桌面端显示小手图标 */
}

.amount-option.selected {
  border-color: #007aff; /* 苹果蓝 */
  background-color: #e6f2ff; /* 选中时的浅蓝色背景 */
  box-shadow: 0 0 0 2px #007aff; /* 模拟选中高亮 */
}

.amount-option .amount-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.amount-option.selected .amount-value {
  color: #007aff;
}

/* 温馨提示 */
.tips-card .tip-item {
  display: flex;
  align-items: flex-start; /* 图标和文字顶部对齐 */
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.tips-card .tip-item:last-child {
  margin-bottom: 0;
}

.tips-card .tip-icon {
  /* 建议使用iconfont或背景图 */
  margin-right: 15rpx;
  color: #007aff;
  font-weight: bold;
  min-width: 30rpx; /* 确保图标空间 */
  text-align: center;
  font-style: italic;
}

/* 按钮样式 - 保持与detail页一致 */
.primary-button.confirm-button {
  background-color: #007aff; /* 苹果蓝 */
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  padding: 25rpx 0;
  text-align: center;
  margin-top: 40rpx;
  transition: background-color 0.2s ease;
  border: none;
  width: 100%;
}

.primary-button.confirm-button:disabled {
  background-color: #c7c7cc; /* 苹果风格的禁用颜色 */
  color: #8e8e93;
  cursor: not-allowed;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background-color: #f0f0f5;
}