/* pages/user/about.wxss */
page {
  background-color: #f9f9f9;
}

.about-page {
  min-height: 100vh;
  background-color: #f9f9f9;
}

.content-area {
  padding: 32rpx;
}

.about-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-top: 48rpx;
  margin-bottom: 24rpx;
  letter-spacing: -0.5rpx;
}

.section-title:first-child {
  margin-top: 0;
}

.section-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #3c3c43;
  margin-bottom: 24rpx;
  text-align: justify;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background-color: #f5f5f7;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.feature-item:last-of-type {
  margin-bottom: 0;
}

.feature-item:active {
  background-color: #ebebed;
  transform: scale(0.99);
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 12rpx;
  letter-spacing: -0.3rpx;
}

.feature-desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #6e6e73;
  text-align: justify;
}

.version-info {
  margin-top: 60rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #e5e5ea;
  text-align: center;
}

.version-text {
  font-size: 26rpx;
  color: #8e8e93;
}

