/* pages/user/collect.wxss */
.collect-page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f2f2f7;
  padding: 0;
  box-sizing: border-box;
}

/* 页面头部 */
.page-header {
  padding: 24rpx 32rpx;
  background-color: #f2f2f7;
}

.header-banner {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.header-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
}

.collect-count {
  font-size: 28rpx;
  color: #1d1d1f;
  font-weight: 500;
  letter-spacing: -0.3rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.clear-all-btn {
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  line-height: 1.3;
  border-radius: 14rpx;
  display: inline-block;
  font-weight: 500;
}

.clear-all-btn:active {
  background-color: #d32f2f;
  transform: scale(0.96);
}

/* 门店列表容器 */
.store-list-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
  background-color: #f2f2f7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
  background-color: #f2f2f7;
  min-height: calc(100vh - 200rpx);
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 16rpx;
  letter-spacing: -0.3rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #8e8e93;
  margin-bottom: 48rpx;
  line-height: 1.4;
  max-width: 400rpx;
}

.explore-btn {
  background-color: #007aff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  line-height: 1.4;
}

.explore-btn:active {
  background-color: #0056cc;
  transform: scale(0.98);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background-color: #f2f2f7;
  min-height: calc(100vh - 200rpx);
}

.loading-animation {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 122, 255, 0.1);
  border-top-color: #007aff;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #8e8e93;
  font-weight: 400;
}