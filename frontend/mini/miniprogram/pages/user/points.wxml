<!--pages/user/points.wxml-->
<wxs module="formatter" src="../../utils/format.wxs"></wxs>
<wxs module="helper">
  // 判断积分是否已过期
  var isExpired = function(expireTime) {
    if (!expireTime) return false;
    var now = getDate();
    // 处理字符串日期格式
    var normalizedDateStr = '';
    for (var i = 0; i < expireTime.length; i++) {
      if (expireTime[i] === '-') {
        normalizedDateStr += '/';
      } else {
        normalizedDateStr += expireTime[i];
      }
    }
    var expire = getDate(normalizedDateStr);
    return expire.getTime() < now.getTime();
  }
  
  module.exports = {
    isExpired: isExpired
  }
</wxs>
<view class="points-page-container">
  <!-- 页面头部 - 积分概览 -->
  <view class="page-header">
    <view class="points-overview">
      <view class="current-points-card">
        <text class="points-label">当前积分</text>
        <text class="points-value">{{currentPoints}}</text>
      </view>
      
      <view class="statistics-row">
        <view class="stat-item">
          <text class="stat-label">累计获得</text>
          <text class="stat-value earned">+{{totalEarned}}</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-label">累计消耗</text>
          <text class="stat-value consumed">-{{totalConsumed}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tabs-container">
    <view class="tabs">
      <view 
        class="tab-item {{activeTab === item.id ? 'active' : ''}}" 
        wx:for="{{tabs}}" 
        wx:key="id"
        data-tab-id="{{item.id}}"
        bindtap="switchTab"
      >
        <text class="tab-text">{{item.name}}</text>
        <view class="tab-indicator" wx:if="{{activeTab === item.id}}"></view>
      </view>
    </view>
  </view>

  <!-- 积分记录列表 -->
  <view class="records-container" wx:if="{{records.length > 0}}">
    <view class="record-item" wx:for="{{records}}" wx:key="id">
      <view class="record-left">
        <view class="record-icon {{item.type === 1 ? 'earned' : 'consumed'}}">
          <text class="icon-text">{{item.type === 1 ? '+' : '-'}}</text>
        </view>
        <view class="record-info">
          <text class="record-desc">{{item.description}}</text>
          <text class="record-time">{{item.createTime}}</text>
          <text class="record-expire" wx:if="{{item.expireTime}}">有效期至 {{item.expireTime}}</text>
        </view>
      </view>
      <view class="record-right">
        <text class="record-points {{item.type === 1 ? 'earned' : 'consumed'}}">
          {{item.type === 1 ? '+' : '-'}}{{item.points}}
        </text>
      </view>
      
      <!-- 已过期水印 -->
      <view class="expired-watermark" wx:if="{{item.type === 1 && item.expireTime && helper.isExpired(item.expireTime)}}">
        <text class="expired-text">已过期</text>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text class="load-more-text">{{loading ? '加载中...' : '上拉加载更多'}}</text>
    </view>
    
    <!-- 没有更多数据 -->
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <text class="no-more-text">没有更多记录了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0 && !loading}}">
    <image class="empty-image" src="/images/default/want-empty.svg" mode="aspectFit"></image>
    <text class="empty-title">暂无积分记录</text>
    <text class="empty-subtitle">{{activeTab === 1 ? '还没有获得积分记录' : activeTab === 2 ? '还没有消耗积分记录' : '还没有积分记录'}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading && records.length === 0}}">
    <view class="loading-animation"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>