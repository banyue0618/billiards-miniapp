/* 预约记录列表页面样式 */
.reserve-list-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30rpx;
}

.header {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1d1d1f;
}

/* 状态筛选 */
.filter-section {
  display: flex;
  background-color: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6e6e73;
  border-radius: 30rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
  flex-shrink: 0;
}

.filter-item.active {
  background-color: #007aff;
  color: #fff;
  font-weight: 500;
}

.reserve-list {
  padding: 0 30rpx;
}

.reserve-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.store-info {
  flex: 1;
}

.store-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.reserve-time {
  display: block;
  font-size: 24rpx;
  color: #86868b;
}

.status-wrap {
  margin-left: 20rpx;
}

.status {
  display: inline-block;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-0 {
  background-color: #e3f2fd;
  color: #2196f3;
}

.status-1 {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-2 {
  background-color: #f3e5f5;
  color: #9c27b0;
}

.status-3 {
  background-color: #ffebee;
  color: #f44336;
}

.status-4 {
  background-color: #eceff1;
  color: #607d8b;
}

.item-body {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.label {
  font-size: 28rpx;
  color: #6e6e73;
}

.value {
  font-size: 28rpx;
  color: #1d1d1f;
  max-width: 60%;
  text-align: right;
  word-break: break-all;
}

.value.amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.value.reservation-no {
  font-size: 24rpx;
  color: #86868b;
  font-family: monospace;
}

.value.pay-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.pay-status-0 {
  background-color: #fff3e0;
  color: #ff9800;
}

.pay-status-1 {
  background-color: #e8f5e9;
  color: #4caf50;
}

.pay-status-2 {
  background-color: #ffebee;
  color: #f44336;
}

.item-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
  border-radius: 40rpx;
  line-height: 1.5;
}

.cancel-btn:active {
  background-color: #ffebee;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #86868b;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #86868b;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #c7c7cc;
}
