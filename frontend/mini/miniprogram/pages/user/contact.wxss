/* pages/user/contact.wxss */
page {
  background-color: #f9f9f9;
}

.contact-page {
  min-height: 100vh;
  background-color: #f9f9f9;
}

.content-area {
  padding: 32rpx;
}

.contact-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 32rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #e5e5ea;
  transition: background-color 0.2s ease;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background-color: #f5f5f7;
}

.contact-item-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.contact-item-content {
  flex: 1;
  min-width: 0;
}

.contact-item-label {
  font-size: 28rpx;
  color: #8e8e93;
  margin-bottom: 8rpx;
}

.contact-item-value {
  font-size: 32rpx;
  color: #1d1d1f;
  font-weight: 500;
  word-break: break-all;
}

.contact-item-arrow {
  font-size: 48rpx;
  color: #c7c7cc;
  font-weight: 300;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 微信客服区域 */
.wechat-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  text-align: center;
}

.wechat-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 32rpx;
}

.wechat-qr-container {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.wechat-qr-placeholder {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #f5f5f7 0%, #e5e5ea 100%);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d2d2d7;
}

.wechat-qr-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.wechat-qr-text {
  font-size: 28rpx;
  color: #8e8e93;
}

.wechat-id {
  font-size: 28rpx;
  color: #6e6e73;
  padding: 16rpx 24rpx;
  background-color: #f5f5f7;
  border-radius: 12rpx;
  display: inline-block;
  margin-top: 16rpx;
}

