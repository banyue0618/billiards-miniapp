# ========================================
# MySQL 5.7 Docker容器配置文件
# ========================================
# 此配置文件用于优化MySQL在Docker容器中的运行性能

[client]
# 客户端默认字符集
default-character-set = utf8mb4
# 连接端口
port = 3306
# 套接字文件
socket = /var/run/mysqld/mysqld.sock

[mysql]
# MySQL命令行工具默认字符集
default-character-set = utf8mb4
# 不要蜂鸣
no-beep

[mysqld]
# ========================================
# 基础配置
# ========================================
# 用户和数据目录
user = mysql
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid

# 端口和绑定地址
port = 3306
bind-address = 0.0.0.0

# ========================================
# 字符集和排序规则配置
# ========================================
# 服务器字符集
character-set-server = utf8mb4
# 服务器排序规则
collation-server = utf8mb4_unicode_ci
# 初始化连接时设置字符集
init_connect = 'SET NAMES utf8mb4'
init_connect = 'SET collation_connection = utf8mb4_unicode_ci'
# 跳过客户端字符集握手
skip-character-set-client-handshake

# ========================================
# 安全和网络配置
# ========================================
# 跳过域名解析（提高连接速度）
skip-name-resolve
# 跳过外部锁定
skip-external-locking
# 表名不区分大小写（适配Windows开发环境）
lower_case_table_names = 1

# ========================================
# 连接配置
# ========================================
# 最大连接数
max_connections = 20
# 最大错误连接数
max_connect_errors = 10
# 交互式连接超时时间（8小时）
interactive_timeout = 28800
# 非交互式连接超时时间（8小时）
wait_timeout = 28800

# ========================================
# 内存配置
# ========================================
# 关键缓冲区大小（MyISAM表索引缓存）
key_buffer_size = 16M
# 最大允许的数据包大小
max_allowed_packet = 64M
# 表打开缓存
table_open_cache = 2000
# 排序缓冲区大小
sort_buffer_size = 2M
# 网络缓冲区大小
net_buffer_length = 32K
# 读缓冲区大小
read_buffer_size = 2M
# 随机读缓冲区大小
read_rnd_buffer_size = 8M
# 批量插入缓冲区大小
bulk_insert_buffer_size = 64M

# ========================================
# MyISAM配置
# ========================================
# MyISAM排序缓冲区大小
#myisam_sort_buffer_size = 128M
# MyISAM最大排序文件大小
#myisam_max_sort_file_size = 10G
# MyISAM修复线程数
#myisam_repair_threads = 1

# ========================================
# InnoDB配置
# ========================================
# InnoDB缓冲池大小（建议设置为可用内存的70-80%）
innodb_buffer_pool_size = 64M
# InnoDB日志文件大小
innodb_log_file_size = 32M
# InnoDB日志缓冲区大小
innodb_log_buffer_size = 8M
# InnoDB刷新日志的频率
innodb_flush_log_at_trx_commit = 2
# InnoDB锁等待超时时间
innodb_lock_wait_timeout = 120
# MySQL 5.7 中已废弃这些文件格式配置，使用默认值
# InnoDB文件格式 - MySQL 5.7+ 中已废弃
# innodb_file_format = Barracuda
# InnoDB行格式 - MySQL 5.7+ 中已废弃
# innodb_file_format_max = Barracuda
# InnoDB页大小（MySQL 5.7 默认16K，通常不需要修改）
# innodb_page_size = 16K

# ========================================
# 查询缓存配置（MySQL 5.7+ 中已废弃）
# ========================================
# MySQL 5.7.20 起查询缓存已被废弃，MySQL 8.0 中完全移除
# 查询缓存大小
# query_cache_size = 32M
# 查询缓存类型（1=开启）
# query_cache_type = 1
# 查询缓存限制
# query_cache_limit = 2M

# ========================================
# 线程配置
# ========================================
# 线程缓存大小
thread_cache_size = 16
# 线程栈大小
thread_stack = 256K

# ========================================
# 临时表配置
# ========================================
# 临时表最大大小
tmp_table_size = 64M
# 内存表最大大小
max_heap_table_size = 64M

# ========================================
# 日志配置
# ========================================
# 错误日志
log-error = /var/lib/mysql/error.log
# 慢查询日志
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow.log
# 慢查询时间阈值（秒）
long_query_time = 1
# 记录没有使用索引的查询
log_queries_not_using_indexes = 1

# ========================================
# 二进制日志配置（主从复制用）
# ========================================
# 注意：如果不需要主从复制，可以注释掉以下配置以避免复杂性
# 服务器ID（必需，用于主从复制）
# server-id = 1
# 二进制日志文件前缀
# log-bin = mysql-bin
# 二进制日志格式
# binlog_format = ROW
# 二进制日志过期时间（天）
# expire_logs_days = 7
# 二进制日志最大大小
# max_binlog_size = 1000M

# 如果需要启用二进制日志，请取消注释以上配置
# 单机部署通常不需要二进制日志

# ========================================
# SQL模式配置
# ========================================
# SQL模式（生产环境建议使用严格模式）
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION

[mysqldump]
# mysqldump工具配置
quick
max_allowed_packet = 64M

# [mysql] 节已在上面定义，这里移除重复
# auto-rehash

[myisamchk]
# myisamchk工具配置
key_buffer_size = 512M
sort_buffer_size = 512M
read_buffer = 8M
write_buffer = 8M

[mysqlhotcopy]
# 热备份工具配置
interactive-timeout
