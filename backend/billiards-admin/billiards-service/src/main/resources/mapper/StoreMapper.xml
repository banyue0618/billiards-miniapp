<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.billiards.mapper.StoreMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.dromara.billiards.domain.entity.BlsStore">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="cover_image" property="coverImage"/>
        <result column="province" property="province"/>
        <result column="city" property="city"/>
        <result column="district" property="district"/>
        <result column="address" property="address"/>
        <result column="latitude" property="latitude"/>
        <result column="longitude" property="longitude"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="business_hours" property="businessHours"/>
        <result column="announcement" property="announcement"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
    </resultMap>
    <select id="findTenantIdByStoreId" resultType="java.lang.String">
        select tenant_id from bls_store where id = #{storeId} limit 1
    </select>

</mapper>
